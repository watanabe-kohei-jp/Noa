{
    "rules": {
        "rooms": {
            "$roomId": {
                ".read": "auth != null && root.child('rooms').child($roomId).child('participants').hasChild(auth.uid)",
                ".write": false
            }
        },
        "userSessions": {
            "$uid": {
                ".read": "auth != null && auth.uid === $uid",
                ".write": "auth != null && auth.uid === $uid"
            }
        }
    }
}
