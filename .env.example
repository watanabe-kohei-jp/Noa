# ===========================================
# Multi-Provider AI API Keys
# ===========================================
# 少なくとも1つのプロバイダーのAPIキーが必要です
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===========================================
# Default Settings
# ===========================================
# 利用可能モデル: gemini-2.5-flash, gemini-2.5-pro, gpt-4o, gpt-4o-mini, claude-sonnet-4-5-20250929, claude-opus-4-20250514
DEFAULT_LLM_MODEL=gemini-2.5-flash

# STT/TTS プロバイダー (openai, google)
DEFAULT_STT_PROVIDER=openai
DEFAULT_TTS_PROVIDER=openai

# ===========================================
# Legacy GCP Settings (optional, for backward compat)
# ===========================================
# PROJECT_ID=your-gcp-project-id
# REGION=us-central1

# ===========================================
# GCP 認証 (Issue #135)
# ===========================================
# Firebase Admin SDK と GCP API は Application Default Credentials (ADC)
# を使用する。SA JSON ファイルは廃止された。
#
# ローカル開発:
#   gcloud auth application-default login
# を実行すれば ~/.config/gcloud/application_default_credentials.json に
# 短命トークンが保存され、firebase-admin / google-cloud SDK が自動利用する。
#
# Cloud Run 上では runtime service account のトークンを自動取得するため
# 環境変数による設定は不要。

# ===========================================
# Firebase Settings
# ===========================================
FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebaseio.com/"
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="your-base64-encoded-encryption-key"

# ===========================================
# Frontend Settings
# ===========================================
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"your-api-key","authDomain":"your-project.firebaseapp.com","projectId":"your-project","storageBucket":"your-project.firebasestorage.app","messagingSenderId":"your-sender-id","appId":"your-app-id","databaseURL":"https://your-project-default-rtdb.firebaseio.com"}
NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8000
# For production: https://your-backend-service-url

# ===========================================
# Live API (Gemini real-time audio/video)
# ===========================================
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# ===========================================
# Optional
# ===========================================
# ROVODEV_API_KEY=your-atlassian-api-key
